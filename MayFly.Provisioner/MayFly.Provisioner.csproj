<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Docker.DotNet.Enhanced" Version="4.2.0" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="8.0.13" />
    <PackageReference Include="Npgsql" Version="8.0.6" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Seeding/northwind.sql" />
    <EmbeddedResource Include="Seeding/northwind.mongo.js" />
    <EmbeddedResource Include="Seeding/ecommerce.sql" />
    <EmbeddedResource Include="Seeding/ecommerce.mongo.js" />
    <EmbeddedResource Include="Seeding/blog.sql" />
    <EmbeddedResource Include="Seeding/blog.mongo.js" />
    <EmbeddedResource Include="Seeding/iot.sql" />
    <EmbeddedResource Include="Seeding/iot.mongo.js" />
  </ItemGroup>

</Project>
